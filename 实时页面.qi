// Qi Web - 实时页面（Phoenix LiveView 式服务端驱动 UI）
//
// v1 诚实定位：**服务端状态 + WebSocket 事件上行 + 整区重渲染下行**。
// 不做 DOM diff——每次事件后服务端重渲染整个片段，客户端整体替换
// #qi-live 的 innerHTML（并尽力保住输入框焦点/光标）。中小页面这个
// 取舍完全够用；DOM diff / 局部 patch 属后续版本。
//
// 一个实时页面由三个用户函数构成（每连接状态用 标准库.JSON 对象句柄承载）：
//   初始状态函数() : 整数                      —— 建一个 J 对象作为该连接的状态
//   渲染函数(状态句柄) : 字符串                 —— 状态 → HTML 片段
//   事件处理函数(状态句柄, 事件名, 载荷JSON) : 整数 —— 处理事件，返回新/同状态句柄
//
// 用法：
//   应用值 = 实时路由(应用值, "/", 初始状态, 渲染, 处理事件);
//   运行应用(应用值);   // 注意：实时页面依赖 WS 升级，必须用同步 运行应用
//
// 协议（内嵌 JS 运行时 ↔ 服务端，均 JSON 文本帧）：
//   上行  {"事件":"加一","载荷":{...}}
//   下行  {"html":"<div>...</div>"}     —— 客户端替换 #qi-live 内容
// 连接建立后服务端先推一帧初始渲染（断线重连后页面自动恢复到服务端状态）。
//
// 客户端声明式事件绑定（事件委托，动态替换后的元素无需重绑）：
//   data-点击="事件名"   —— click 上行，载荷 {}
//   data-输入="事件名"   —— input/change 上行，载荷 {"value": 当前值}
//   data-提交="事件名"   —— 表单 submit 上行，载荷为各字段名值对
//
// 限制（v1）：
// - 路由路径用 ASCII（含中文的路由 path 在 Rust 镜像表会 panic）
// - 每个 WS 连接一份独立状态；连接断开状态即释放，无跨连接共享/广播
// - 断线重连为固定 1 秒退避
包 Web;

导入 标准库.字符串;
导入 标准库.WebSocket 作为 WS;
导入 标准库.JSON 作为 J;

// ── 注册 ────────────────────────────────────────────────────────

// 注册一个实时页面：GET 路径 → 完整 HTML（布局 + 初始渲染 + JS 运行时）；
// 路径 + "/ws"（路径为 "/" 时是 "/ws"）→ WebSocket 事件循环。
公开 函数 实时路由(应用值: 应用, 路径: 字符串, 初始状态函数: 函数(): 整数, 渲染函数: 函数(整数): 字符串, 事件处理函数: 函数(整数, 字符串, 字符串): 整数) : 应用 {
    变量 ws路径: 字符串 = 实时WS路径(路径);

    // GET：初始状态 → 初始渲染 → 完整页面。状态仅用于首屏渲染，用完即释放；
    // 真正的会话状态在 WS 连接建立时重新创建。
    变量 页面处理器: 函数(上下文): 响应 = 闭包(上下文值: 上下文): 响应 {
        变量 首屏状态: 整数 = 初始状态函数();
        变量 初始片段: 字符串 = 渲染函数(首屏状态);
        J.删除(首屏状态);
        返回 HTML(实时页面布局("Qi 实时页面", ws路径, 初始片段));
    };
    应用值 = 获取(应用值, 路径, 页面处理器);

    // WS：每连接一个事件循环 goroutine（由 服务器.qi 的 尝试WS升级 调起）
    变量 ws处理器: 函数(整数): 整数 = 闭包(ws句柄: 整数): 整数 {
        返回 实时连接循环(ws句柄, 初始状态函数, 渲染函数, 事件处理函数);
    };
    应用值 = WS路由(应用值, ws路径, ws处理器);
    返回 应用值;
}

// 页面路径 → WS 路径："/" → "/ws"，"/counter" → "/counter/ws"
函数 实时WS路径(路径: 字符串) : 字符串 {
    如果 (字符串::等于(路径, "/") == 1) {
        返回 "/ws";
    }
    如果 (字符串::结束于(路径, "/") == 1) {
        返回 路径 + "ws";
    }
    返回 路径 + "/ws";
}

// ── 每连接事件循环 ──────────────────────────────────────────────

函数 实时连接循环(ws句柄: 整数, 初始状态函数: 函数(): 整数, 渲染函数: 函数(整数): 字符串, 事件处理函数: 函数(整数, 字符串, 字符串): 整数) : 整数 {
    变量 状态: 整数 = 初始状态函数();

    // 连接建立即推一帧当前渲染：断线重连后页面自动回到服务端状态
    实时发送整区(ws句柄, 渲染函数(状态));

    变量 继续循环: 整数 = 1;
    当 (继续循环 == 1 与 WS::已连接(ws句柄) == 1) {
        变量 消息: 字符串 = WS::接收文本(ws句柄);
        如果 (字符串::字节长度(消息) == 0) {
            // 客户端断开
            继续循环 = 0;
        } 否则 {
            变量 消息对象: 整数 = J.解码(消息);
            如果 (消息对象 > 0) {
                变量 事件名: 字符串 = J.获取字符串(消息对象, "事件");
                如果 (字符串::字节长度(事件名) > 0) {
                    // 载荷缺省为 {}；J.转字符串 借助句柄树取子对象文本
                    变量 载荷串: 字符串 = "{}";
                    如果 (J.是否包含键(消息对象, "载荷") == 1) {
                        变量 载荷对象: 整数 = J.获取对象(消息对象, "载荷");
                        如果 (载荷对象 > 0) {
                            载荷串 = J.转字符串(载荷对象);
                        }
                    }
                    // 事件处理可能返回新句柄（换状态），也可能原样返回
                    状态 = 事件处理函数(状态, 事件名, 载荷串);
                    实时发送整区(ws句柄, 渲染函数(状态));
                }
                J.删除(消息对象);
            }
            // 解析失败的帧直接忽略（不重渲染、不断连）
        }
    }

    // 连接断开：释放该连接的状态句柄
    J.删除(状态);
    返回 0;
}

// 下行一帧 {"html": "..."}——经 J 对象序列化，转义由 JSON 层保证
函数 实时发送整区(ws句柄: 整数, 片段: 字符串) : 整数 {
    变量 帧对象: 整数 = J.创建对象();
    J.设置字符串(帧对象, "html", 片段);
    变量 帧文本: 字符串 = J.转字符串(帧对象);
    J.删除(帧对象);
    返回 WS::发送文本(ws句柄, 帧文本);
}

// ── 页面布局与内嵌 JS 运行时 ────────────────────────────────────

// 完整 HTML 页：<div id="qi-live">初始渲染</div> + JS 运行时。
// 需要自定义布局的应用可以自己拼页面（引用 实时运行时脚本 即可）再
// 用 获取 + WS路由 手工挂载；实时路由 走这个默认布局。
公开 函数 实时页面布局(标题: 字符串, WS路径: 字符串, 初始片段: 字符串) : 字符串 {
    变量 页: 字符串 = "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n";
    页 = 页 + "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n";
    页 = 页 + "<title>" + 转义HTML(标题) + "</title>\n";
    页 = 页 + "</head>\n<body>\n";
    页 = 页 + "<div id=\"qi-live\">" + 初始片段 + "</div>\n";
    页 = 页 + 实时运行时脚本(WS路径);
    页 = 页 + "\n</body>\n</html>\n";
    返回 页;
}

// 内嵌 JS 运行时（无依赖）：
// - 自动连同 host 的 WS；断线 1s 后重连
// - 事件委托：data-点击 / data-输入 / data-提交 三种声明式绑定
// - 收到 {html} 帧 → 替换 #qi-live 内容，并尽力恢复输入焦点/光标
公开 函数 实时运行时脚本(WS路径: 字符串) : 字符串 {
    变量 s: 字符串 = "<script>\n(function(){\n";
    s = s + "var wsPath='" + WS路径 + "';\n";
    s = s + "var ws=null;\n";
    s = s + "function connect(){\n";
    s = s + "  var proto=location.protocol==='https:'?'wss://':'ws://';\n";
    s = s + "  ws=new WebSocket(proto+location.host+wsPath);\n";
    s = s + "  ws.onmessage=function(e){\n";
    s = s + "    var m;try{m=JSON.parse(e.data);}catch(err){return;}\n";
    s = s + "    if(m.html===undefined){return;}\n";
    s = s + "    var live=document.getElementById('qi-live');\n";
    s = s + "    if(!live){return;}\n";
    // 整区替换会打断正在输入的 input——先记住焦点元素的 data-输入 键、
    // 值与光标位置，替换后找同键元素恢复
    s = s + "    var f=document.activeElement,fk=null,fv=null,s1=null,s2=null;\n";
    s = s + "    if(f&&f.getAttribute){fk=f.getAttribute('data-输入');fv=f.value;\n";
    s = s + "      try{s1=f.selectionStart;s2=f.selectionEnd;}catch(e2){}}\n";
    s = s + "    live.innerHTML=m.html;\n";
    s = s + "    if(fk){var nf=live.querySelector('[data-输入=\"'+fk+'\"]');\n";
    s = s + "      if(nf){nf.focus();if(fv!==null&&fv!==undefined){nf.value=fv;}\n";
    s = s + "        if(s1!==null){try{nf.setSelectionRange(s1,s2);}catch(e3){}}}}\n";
    s = s + "  };\n";
    s = s + "  ws.onclose=function(){setTimeout(connect,1000);};\n";
    s = s + "}\n";
    s = s + "function send(ev,payload){\n";
    s = s + "  if(ws&&ws.readyState===1){ws.send(JSON.stringify({'事件':ev,'载荷':payload||{}}));}\n";
    s = s + "}\n";
    s = s + "document.addEventListener('click',function(e){\n";
    s = s + "  var el=e.target.closest('[data-点击]');\n";
    s = s + "  if(el){send(el.getAttribute('data-点击'),{});}\n";
    s = s + "});\n";
    s = s + "document.addEventListener('input',function(e){\n";
    s = s + "  var el=e.target.closest('[data-输入]');\n";
    s = s + "  if(el){send(el.getAttribute('data-输入'),{value:el.value});}\n";
    s = s + "});\n";
    s = s + "document.addEventListener('submit',function(e){\n";
    s = s + "  var f4=e.target.closest('[data-提交]');\n";
    s = s + "  if(f4){e.preventDefault();var d={};\n";
    s = s + "    new FormData(f4).forEach(function(v,k){d[k]=v;});\n";
    s = s + "    send(f4.getAttribute('data-提交'),d);}\n";
    s = s + "});\n";
    s = s + "connect();\n";
    s = s + "})();\n</script>";
    返回 s;
}

// ── HTML 转义（渲染函数里输出用户输入前先过这层，防注入）────────

公开 函数 转义HTML(文本: 字符串) : 字符串 {
    变量 结果值: 字符串 = 字符串::替换(文本, "&", "&amp;");
    结果值 = 字符串::替换(结果值, "<", "&lt;");
    结果值 = 字符串::替换(结果值, ">", "&gt;");
    结果值 = 字符串::替换(结果值, "\"", "&quot;");
    结果值 = 字符串::替换(结果值, "'", "&#39;");
    返回 结果值;
}
