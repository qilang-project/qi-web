// Qi Web - 聊天 —— 开箱即用的 AI 聊天（qi-web × qi-harness 电池全含）
//
// 一行挂载一个完整的流式 AI 聊天：独立聊天页 + SSE 流 + Harness 代理，
// 模型默认连本机 ollama（QI_LLM_BASE/KEY/MODEL 可覆盖成任意 OpenAI 兼容端点）。
// 需要工具（查库/下单等）的复杂场景，用 聊天界面 + 事件流.SSE流式对话 自建 handler
// （见 聊天界面.qi 头注释）；这里是「只要能聊」的零配置版本。
//
// 用法：
//   导入 Web.聊天::{挂载简单聊天};
//   应用值 = 挂载简单聊天(应用值, "/chat", "小助手",
//       "你好，我能帮你解答问题。", "你是网站的客服助手，回答简洁友好。");
//   // → GET /chat 聊天页；GET /chat/stream SSE。默认本机 ollama。
//
// 注意（v1）：配置存模块级变量，一个进程只支持挂一个简单聊天。
// 多个/带工具的场景走 聊天界面 + SSE流式对话 自建。
包 Web;

导入 标准库.字符串;
导入 标准库.操作系统 作为 系统;
导入 Harness::{
    模型配置, 大模型, 配置系统提示, 开启会话,
    创建代理, 流式运行, 关闭代理
};

变量 聊天标题: 字符串 = "AI 助手";
变量 聊天欢迎: 字符串 = "你好，问我点什么？";
变量 聊天提示: 字符串 = "你是一个乐于助人的助手，回答简洁。";
变量 聊天流路径: 字符串 = "/chat/stream";

// 一行挂载：路径 = 聊天页，路径+"/stream" = SSE 流。
公开 函数 挂载简单聊天(应用值: 应用, 路径: 字符串, 标题: 字符串, 欢迎语: 字符串, 系统提示: 字符串) : 应用 {
    聊天标题 = 标题;
    聊天欢迎 = 欢迎语;
    聊天提示 = 系统提示;
    聊天流路径 = 路径 + "/stream";
    变量 新应用: 应用 = 获取(应用值, 路径, 简单聊天页);
    新应用 = 获取(新应用, 聊天流路径, 简单聊天流);
    返回 新应用;
}

函数 取端点() : 字符串 {
    变量 e: 字符串 = 系统.获取环境变量("QI_LLM_BASE");
    如果 (字符串::字节长度(e) == 0) { 返回 "http://127.0.0.1:11434/v1"; }
    返回 e;
}
函数 取密钥() : 字符串 {
    变量 k: 字符串 = 系统.获取环境变量("QI_LLM_KEY");
    如果 (字符串::字节长度(k) == 0) { 返回 "ollama"; }
    返回 k;
}
函数 取模型() : 字符串 {
    变量 m: 字符串 = 系统.获取环境变量("QI_LLM_MODEL");
    如果 (字符串::字节长度(m) == 0) { 返回 "ornith"; }
    返回 m;
}

// GET 路径：一个自带布局的独立聊天页（复用 聊天界面 的 UI）
函数 简单聊天页(上下文值: 上下文) : 响应 {
    变量 页: 字符串 = "<!doctype html><html lang=\"zh-CN\"><head><meta charset=\"utf-8\">"
        + "<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">"
        + "<title>" + 转义HTML(聊天标题) + "</title>"
        + "<style>body{margin:0;background:#f8fafc;font-family:'PingFang SC','Microsoft YaHei',system-ui,sans-serif;padding:24px}</style>"
        + "</head><body>";
    页 = 页 + 聊天界面(聊天标题, 聊天欢迎, 聊天流路径);
    页 = 页 + "</body></html>";
    返回 HTML(页);
}

// GET 路径/stream：SSE 流式跑一个无工具代理
函数 简单聊天流(上下文值: 上下文) : 响应 {
    变量 问题: 字符串 = 查询参数(上下文值, "q");
    变量 配置: 模型配置 = 大模型(取端点(), 取密钥(), 取模型());
    配置 = 配置系统提示(配置, 聊天提示);
    变量 会话: 整数 = 开启会话(配置);
    如果 (会话 <= 0) {
        SSE开始(上下文值);
        SSE发送(上下文值, "message", "（AI 连接失败，请检查模型服务是否在运行）");
        SSE发送(上下文值, "message", "[完成]");
        SSE结束(上下文值);
        返回 SSE完成响应();
    }
    变量 代理值: 代理 = 创建代理(聊天标题, 会话);
    返回 SSE流式对话(上下文值, "message", 闭包(推送: 函数(字符串): 整数): 整数 {
        流式运行(代理值, 问题, 推送);
        关闭代理(代理值);
        返回 1;
    });
}
