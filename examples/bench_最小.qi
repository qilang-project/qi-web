包 主程序;

// 基线：最小 GET / handler — 衡量框架开销 + accept loop + 中间件框架
// wrk -t4 -c100 -d10s http://127.0.0.1:6790/

导入 Web::{应用, 上下文, 响应, 创建应用, 配置, 获取, 文本, 运行应用};

函数 处理(上下文值: 上下文) : 响应 {
    返回 文本("ok");
}

函数 入口() {
    变量 应用值: 应用 = 创建应用();
    应用值 = 配置(应用值, "127.0.0.1", 6790);
    应用值 = 获取(应用值, "/", 处理);
    运行应用(应用值);
}
