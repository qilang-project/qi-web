包 主程序;

导入 Web::{应用, 上下文, 响应, 创建应用, 配置, 获取, 文本, HTML, JSON, 接受, 内容是, 优先接受, 运行应用_异步};

函数 处理api(上下文值: 上下文) : 响应 {
    变量 best: 字符串 = 优先接受(上下文值, "json,html,text");
    如果 (字符串::等于(best, "json") == 1) {
        返回 JSON("{\"format\":\"json\"}");
    }
    如果 (字符串::等于(best, "html") == 1) {
        返回 HTML("<h1>html</h1>");
    }
    返回 文本("text");
}

函数 入口() {
    变量 应用值: 应用 = 创建应用();
    应用值 = 配置(应用值, "127.0.0.1", 6811);
    应用值 = 获取(应用值, "/api", 处理api);
    运行应用_异步(应用值);
}
