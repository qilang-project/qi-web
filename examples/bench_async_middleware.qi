包 主程序;

// 异步 + CORS + 缓存中间件，对照 bench_最小_异步 多了真实 production 中间件
导入 Web::{
    应用, 上下文, 响应,
    创建应用, 配置, 获取,
    文本,
    使用跨域配置, 使用静态缓存,
    运行应用_异步
};

函数 处理(上下文值: 上下文) : 响应 {
    返回 文本("ok");
}

函数 入口() {
    变量 应用值: 应用 = 创建应用();
    应用值 = 配置(应用值, "127.0.0.1", 6798);
    应用值 = 使用跨域配置(
        应用值,
        "*",
        "GET, POST, OPTIONS",
        "Content-Type",
        0,
        300
    );
    应用值 = 使用静态缓存(应用值, 60);
    应用值 = 获取(应用值, "/", 处理);
    运行应用_异步(应用值);
}
