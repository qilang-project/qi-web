包 主程序;

导入 Web::{应用, 上下文, 响应, 创建应用, 配置, 获取, 文本, 真实IP, 真实协议, 真实主机, 是HTTPS, 运行应用_异步};

函数 处理(上下文值: 上下文) : 响应 {
    变量 报告: 字符串 = "ip=" + 真实IP(上下文值);
    报告 = 报告 + " proto=" + 真实协议(上下文值);
    报告 = 报告 + " host=" + 真实主机(上下文值);
    报告 = 报告 + " https=" + 整数转字符串(是HTTPS(上下文值));
    返回 文本(报告);
}

函数 入口() {
    变量 应用值: 应用 = 创建应用();
    应用值 = 配置(应用值, "127.0.0.1", 6812);
    应用值 = 获取(应用值, "/", 处理);
    运行应用_异步(应用值);
}
