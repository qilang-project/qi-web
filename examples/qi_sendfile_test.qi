包 主程序;

导入 Web::{应用, 上下文, 响应, 创建应用, 配置, 获取, 文本, 发送文件, 下载文件, 运行应用_异步};

函数 处理view(上下文值: 上下文) : 响应 {
    返回 发送文件("/tmp/test_file.txt");
}

函数 处理download(上下文值: 上下文) : 响应 {
    返回 下载文件("/tmp/test_file.txt", "report.txt");
}

函数 处理404(上下文值: 上下文) : 响应 {
    返回 发送文件("/tmp/不存在.txt");
}

函数 入口() {
    变量 应用值: 应用 = 创建应用();
    应用值 = 配置(应用值, "127.0.0.1", 6810);
    应用值 = 获取(应用值, "/view", 处理view);
    应用值 = 获取(应用值, "/download", 处理download);
    应用值 = 获取(应用值, "/missing", 处理404);
    运行应用_异步(应用值);
}
