// Qi Web - 事件流（Server-Sent Events / SSE）
//
// 基于现有 chunked 流式机制（服务器.qi 的 流发送文本块 / 流结束）之上的
// SSE 协议层。handler 用法：
//
//   函数 推送处理(上下文值: 上下文) : 响应 {
//       SSE开始(上下文值);
//       SSE发送(上下文值, "message", "第一条");
//       SSE发送(上下文值, "message", "第二条");
//       SSE结束(上下文值);
//       返回 SSE完成响应();   // 状态码 0 = 已自行写完，框架不再写
//   }
//
// 说明：
// - 响应头走 Transfer-Encoding: chunked + Connection: close。curl -N 与浏览器
//   EventSource 都原生支持 chunked SSE；连接在 SSE结束 后由框架关闭。
// - 浏览器 EventSource 在连接关闭后会自动重连并重放请求——一次性流（如一问
//   一答的 LLM 聊天）应发一个结束事件（如 event: done），前端收到后 es.close()。
// - 仅支持同步 运行应用 路径（流式响应依赖 ctx.客户端句柄，与压缩/流式
//   中间件同一约定）；运行应用_异步 不支持流式，见 服务器.qi 注释。
// - v1 取舍：不做服务端心跳定时器与 Last-Event-ID 断点续推；需要时 handler
//   可自行周期调 SSE注释 保活、用 SSE发送带ID 标记事件 id。
包 Web;

导入 标准库.字符串;
导入 标准库.网络;
导入 标准库.列表 作为 列表库;

// 向客户端写 SSE 响应头。返回 TCP 写入结果值（<0 失败）；
// 客户端句柄不可用（如异步路径 / 单测直调）返回 -1。
公开 函数 SSE开始(上下文值: 上下文) : 整数 {
    变量 客户端: 整数 = 上下文值.客户端句柄;
    如果 (客户端 <= 0) {
        返回 -1;
    }
    变量 头部: 字符串 = "HTTP/1.1 200 OK\r\n";
    头部 = 头部 + "Content-Type: text/event-stream; charset=utf-8\r\n";
    头部 = 头部 + "Cache-Control: no-cache\r\n";
    // 反代（nginx 等）看到这个头会关闭响应缓冲，逐事件透传
    头部 = 头部 + "X-Accel-Buffering: no\r\n";
    头部 = 头部 + "Transfer-Encoding: chunked\r\n";
    头部 = 头部 + "Connection: close\r\n";
    头部 = 头部 + "\r\n";
    返回 网络::TCP写入(客户端, 头部);
}

// 把一段数据按 SSE 规范拼成 data: 行。数据内的换行拆成多条 data:
// （接收端 EventSource 会用 \n 重新拼回），兼容 \r\n 行尾。
函数 SSE数据行(数据: 字符串) : 字符串 {
    // 无换行的常见情形（LLM token 片段）直接单行，省一次分割
    如果 (字符串::查找(数据, "\n") < 0) {
        返回 "data: " + 数据 + "\n";
    }
    变量 结果值: 字符串 = "";
    变量 行列表: 整数 = 字符串::分割(数据, "\n");
    变量 索引: 整数 = 0;
    变量 总数: 整数 = 列表库::字符串列表大小(行列表);
    当 (索引 < 总数) {
        变量 行: 字符串 = 列表库::获取字符串(行列表, 索引);
        // 去掉 \r\n 行尾残留的 \r
        如果 (字符串::结束于(行, "\r") == 1) {
            行 = 字符串::子串(行, 0, 字符串::字节长度(行) - 1);
        }
        结果值 = 结果值 + "data: " + 行 + "\n";
        索引 = 索引 + 1;
    }
    返回 结果值;
}

// 发送一条完整 SSE 事件帧：event: X\ndata: Y\n\n。
// 事件名为空则不写 event 行（EventSource 按默认 message 事件派发）。
// 返回写出的字节数（<0 失败）。
公开 函数 SSE发送(上下文值: 上下文, 事件名: 字符串, 数据: 字符串) : 整数 {
    如果 (上下文值.客户端句柄 <= 0) {
        返回 -1;
    }
    变量 帧: 字符串 = "";
    如果 (字符串::字节长度(事件名) > 0) {
        帧 = "event: " + 事件名 + "\n";
    }
    帧 = 帧 + SSE数据行(数据) + "\n";
    返回 流发送文本块(上下文值.客户端句柄, 帧);
}

// 只发 data:（默认 message 事件）的便捷版
公开 函数 SSE发送数据(上下文值: 上下文, 数据: 字符串) : 整数 {
    返回 SSE发送(上下文值, "", 数据);
}

// 带事件 id 的版本：id: N\nevent: X\ndata: Y\n\n。
// 客户端断线重连时会带 Last-Event-ID 头（v1 不做服务端续推，仅透出 id）。
公开 函数 SSE发送带ID(上下文值: 上下文, 事件ID: 字符串, 事件名: 字符串, 数据: 字符串) : 整数 {
    如果 (上下文值.客户端句柄 <= 0) {
        返回 -1;
    }
    变量 帧: 字符串 = "id: " + 事件ID + "\n";
    如果 (字符串::字节长度(事件名) > 0) {
        帧 = 帧 + "event: " + 事件名 + "\n";
    }
    帧 = 帧 + SSE数据行(数据) + "\n";
    返回 流发送文本块(上下文值.客户端句柄, 帧);
}

// SSE 注释行（": ..."），客户端忽略内容——可作保活心跳
公开 函数 SSE注释(上下文值: 上下文, 注释: 字符串) : 整数 {
    如果 (上下文值.客户端句柄 <= 0) {
        返回 -1;
    }
    返回 流发送文本块(上下文值.客户端句柄, ": " + 注释 + "\n\n");
}

// 收尾：发 chunked 终止块（0\r\n\r\n），此后框架关闭连接
公开 函数 SSE结束(上下文值: 上下文) : 整数 {
    如果 (上下文值.客户端句柄 <= 0) {
        返回 -1;
    }
    返回 流结束(上下文值.客户端句柄);
}

// 状态码 0 的"已自行流式写完"响应——handler 收尾后 返回 SSE完成响应()
公开 函数 SSE完成响应() : 响应 {
    返回 新建 响应 {
        状态码: 0,
        状态文本: "",
        头部: "",
        主体: ""
    };
}
