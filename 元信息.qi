// Qi Web - 元信息 / SEO
//
// 每个 web app 都要在 <head> 里塞一堆 SEO / 社交分享标签（title/description、
// Open Graph、Twitter Card、canonical），还要生成 robots.txt / sitemap.xml，
// 想被 AI 引擎（ChatGPT/Perplexity/Claude/Google AI）引用还得写 JSON-LD 结构化数据。
// 这些以前在 aione、家有小奇 里各手搓一遍。这里沉淀成框架原语。
//
// 用法（元信息 是结构体，须走 Web::{} 公开导入路径，不要用 Web.元信息::{}——
// 跨包子模块路径下 codegen 认不出结构体）：
//   导入 Web::{元信息, 创建元信息, 渲染元信息};
//   变量 头: 字符串 = 渲染元信息(创建元信息(
//       "标题", "一句话描述", "https://站点/", "https://站点/og.png"));
//   // 把 头 拼进你的 <head> ... </head>
//
//   // 结构化数据（GEO）：
//   变量 节点们: 字符串 = 组织节点("站点名","https://站点/","https://站点/logo.svg","描述")
//       + "," + 网站节点("站点名","https://站点/");
//   变量 脚本: 字符串 = 渲染结构化(节点们);   // <script type="application/ld+json">...
//
//   // robots.txt / sitemap.xml 处理器：
//   获取(应用值, "/robots.txt", robots处理器);   // 内部 返回 文本(生成robots("https://站点/sitemap.xml"))
//   获取(应用值, "/sitemap.xml", 站点地图处理器); // 返回 XML(生成站点地图("https://站点/\nhttps://站点/courses"))

包 Web;

导入 标准库.字符串;

公开 类型 元信息 {
    标题: 字符串,
    描述: 字符串,
    规范链接: 字符串,   // canonical + og:url，应为绝对 URL
    站点名: 字符串,
    图: 字符串,         // og:image / twitter:image，应为绝对 URL（1200x630 最佳）
    图宽: 整数,
    图高: 整数,
    语言: 字符串,       // og:locale，如 "zh_CN"
    主题色: 字符串,     // theme-color，如 "#f5a623"
    关键词: 字符串,     // meta keywords（可留空）
    种类: 字符串,       // og:type，如 "website" / "article"
}

// ── HTML 属性值转义：& < > " 四个必转，防止属性提前闭合 / 注入 ──
公开 函数 转义属性(文本: 字符串) : 字符串 {
    变量 结果值: 字符串 = 文本;
    结果值 = 字符串::替换(结果值, "&", "&amp;");
    结果值 = 字符串::替换(结果值, "<", "&lt;");
    结果值 = 字符串::替换(结果值, ">", "&gt;");
    结果值 = 字符串::替换(结果值, "\"", "&quot;");
    返回 结果值;
}

// ── JSON 字符串值转义：\ " 换行 回车 制表 ──
公开 函数 转义JSON(文本: 字符串) : 字符串 {
    变量 结果值: 字符串 = 文本;
    结果值 = 字符串::替换(结果值, "\\", "\\\\");
    结果值 = 字符串::替换(结果值, "\"", "\\\"");
    结果值 = 字符串::替换(结果值, "\n", "\\n");
    结果值 = 字符串::替换(结果值, "\r", "\\r");
    结果值 = 字符串::替换(结果值, "\t", "\\t");
    返回 结果值;
}

// ── 构造元信息，带常用默认值（中文站点） ──
公开 函数 创建元信息(标题: 字符串, 描述: 字符串, 规范链接: 字符串, 图: 字符串) : 元信息 {
    返回 新建 元信息 {
        标题: 标题,
        描述: 描述,
        规范链接: 规范链接,
        站点名: "",
        图: 图,
        图宽: 1200,
        图高: 630,
        语言: "zh_CN",
        主题色: "",
        关键词: "",
        种类: "website"
    };
}

// 链式 setter（返回新值，函数式风格，和 设置响应头 一致）
公开 函数 设站点名(信息: 元信息, 站点名: 字符串) : 元信息 {
    变量 新值: 元信息 = 信息; 新值.站点名 = 站点名; 返回 新值;
}
公开 函数 设主题色(信息: 元信息, 颜色: 字符串) : 元信息 {
    变量 新值: 元信息 = 信息; 新值.主题色 = 颜色; 返回 新值;
}
公开 函数 设关键词(信息: 元信息, 关键词: 字符串) : 元信息 {
    变量 新值: 元信息 = 信息; 新值.关键词 = 关键词; 返回 新值;
}
公开 函数 设语言(信息: 元信息, 语言: 字符串) : 元信息 {
    变量 新值: 元信息 = 信息; 新值.语言 = 语言; 返回 新值;
}
公开 函数 设种类(信息: 元信息, 种类: 字符串) : 元信息 {
    变量 新值: 元信息 = 信息; 新值.种类 = 种类; 返回 新值;
}

函数 元标签(名称: 字符串, 内容: 字符串) : 字符串 {
    返回 "    <meta name=\"" + 名称 + "\" content=\"" + 转义属性(内容) + "\" />\n";
}
函数 OG标签(属性: 字符串, 内容: 字符串) : 字符串 {
    返回 "    <meta property=\"" + 属性 + "\" content=\"" + 转义属性(内容) + "\" />\n";
}

// ── 渲染整段 <head> 里的 SEO / 社交标签 ──
// 返回可直接拼进 <head>…</head> 的字符串。title/description/canonical 恒有；
// OG/Twitter 齐全；有图走大图卡 summary_large_image，无图走 summary。
公开 函数 渲染元信息(信息: 元信息) : 字符串 {
    变量 有图: 整数 = 0;
    如果 (字符串::字节长度(信息.图) > 0) { 有图 = 1; }

    变量 输出: 字符串 = "";
    输出 = 输出 + "    <title>" + 转义属性(信息.标题) + "</title>\n";
    输出 = 输出 + 元标签("description", 信息.描述);
    如果 (字符串::字节长度(信息.关键词) > 0) {
        输出 = 输出 + 元标签("keywords", 信息.关键词);
    }
    输出 = 输出 + 元标签("robots", "index, follow, max-image-preview:large, max-snippet:-1");
    如果 (字符串::字节长度(信息.主题色) > 0) {
        输出 = 输出 + 元标签("theme-color", 信息.主题色);
    }
    如果 (字符串::字节长度(信息.规范链接) > 0) {
        输出 = 输出 + "    <link rel=\"canonical\" href=\"" + 转义属性(信息.规范链接) + "\" />\n";
    }

    // Open Graph
    输出 = 输出 + OG标签("og:type", 信息.种类);
    如果 (字符串::字节长度(信息.站点名) > 0) {
        输出 = 输出 + OG标签("og:site_name", 信息.站点名);
    }
    如果 (字符串::字节长度(信息.语言) > 0) {
        输出 = 输出 + OG标签("og:locale", 信息.语言);
    }
    如果 (字符串::字节长度(信息.规范链接) > 0) {
        输出 = 输出 + OG标签("og:url", 信息.规范链接);
    }
    输出 = 输出 + OG标签("og:title", 信息.标题);
    输出 = 输出 + OG标签("og:description", 信息.描述);
    如果 (有图 == 1) {
        输出 = 输出 + OG标签("og:image", 信息.图);
        输出 = 输出 + OG标签("og:image:secure_url", 信息.图);
        输出 = 输出 + OG标签("og:image:width", 整数转字符串(信息.图宽));
        输出 = 输出 + OG标签("og:image:height", 整数转字符串(信息.图高));
    }

    // Twitter Card
    如果 (有图 == 1) {
        输出 = 输出 + 元标签("twitter:card", "summary_large_image");
        输出 = 输出 + 元标签("twitter:image", 信息.图);
    } 否则 {
        输出 = 输出 + 元标签("twitter:card", "summary");
    }
    输出 = 输出 + 元标签("twitter:title", 信息.标题);
    输出 = 输出 + 元标签("twitter:description", 信息.描述);
    返回 输出;
}

// ══════════════ JSON-LD 结构化数据（GEO：让 AI 引擎能引用） ══════════════
// 每个 *节点 返回一个 JSON 对象串（无外层数组）；用 "," 拼多个，交给
// 渲染结构化 / JSONLD文档 包成 @graph。字段值都经 转义JSON。

// 组织 / EducationalOrganization 通用：logo、图可留空串跳过
公开 函数 组织节点(名: 字符串, 网址: 字符串, logo: 字符串, 描述: 字符串) : 字符串 {
    变量 j: 字符串 = "{\"@type\":\"Organization\",\"@id\":\"" + 转义JSON(网址) + "#org\"";
    j = j + ",\"name\":\"" + 转义JSON(名) + "\"";
    j = j + ",\"url\":\"" + 转义JSON(网址) + "\"";
    如果 (字符串::字节长度(logo) > 0) {
        j = j + ",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"" + 转义JSON(logo) + "\"}";
    }
    如果 (字符串::字节长度(描述) > 0) {
        j = j + ",\"description\":\"" + 转义JSON(描述) + "\"";
    }
    j = j + "}";
    返回 j;
}

公开 函数 网站节点(名: 字符串, 网址: 字符串) : 字符串 {
    变量 j: 字符串 = "{\"@type\":\"WebSite\",\"@id\":\"" + 转义JSON(网址) + "#website\"";
    j = j + ",\"name\":\"" + 转义JSON(名) + "\"";
    j = j + ",\"url\":\"" + 转义JSON(网址) + "\"";
    j = j + ",\"publisher\":{\"@id\":\"" + 转义JSON(网址) + "#org\"}";
    j = j + "}";
    返回 j;
}

// 简单课程节点（provider 指向组织节点的 @id）。复杂 CourseInstance/offers 自行拼原始 JSON。
公开 函数 课程节点(名: 字符串, 描述: 字符串, 站点URL: 字符串) : 字符串 {
    变量 j: 字符串 = "{\"@type\":\"Course\"";
    j = j + ",\"name\":\"" + 转义JSON(名) + "\"";
    j = j + ",\"description\":\"" + 转义JSON(描述) + "\"";
    j = j + ",\"provider\":{\"@id\":\"" + 转义JSON(站点URL) + "#org\"}";
    j = j + "}";
    返回 j;
}

// FAQ：FAQ问答 造一个 Question；多个用 "," 拼；FAQ节点 包成 FAQPage
公开 函数 FAQ问答(问: 字符串, 答: 字符串) : 字符串 {
    变量 j: 字符串 = "{\"@type\":\"Question\",\"name\":\"" + 转义JSON(问) + "\"";
    j = j + ",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"" + 转义JSON(答) + "\"}}";
    返回 j;
}
公开 函数 FAQ节点(问答们: 字符串) : 字符串 {
    返回 "{\"@type\":\"FAQPage\",\"mainEntity\":[" + 问答们 + "]}";
}

// 面包屑：面包屑项 造一项；多项用 "," 拼；面包屑节点 包成 BreadcrumbList
公开 函数 面包屑项(位置: 整数, 名: 字符串, 链接: 字符串) : 字符串 {
    变量 j: 字符串 = "{\"@type\":\"ListItem\",\"position\":" + 整数转字符串(位置);
    j = j + ",\"name\":\"" + 转义JSON(名) + "\",\"item\":\"" + 转义JSON(链接) + "\"}";
    返回 j;
}
公开 函数 面包屑节点(项们: 字符串) : 字符串 {
    返回 "{\"@type\":\"BreadcrumbList\",\"itemListElement\":[" + 项们 + "]}";
}

// 把逗号拼好的节点们包进 @graph；仅返回 JSON 文本
公开 函数 JSONLD文档(节点们: 字符串) : 字符串 {
    返回 "{\"@context\":\"https://schema.org\",\"@graph\":[" + 节点们 + "]}";
}

// 包成可直接塞进 <head> 的 <script type="application/ld+json"> 块
公开 函数 渲染结构化(节点们: 字符串) : 字符串 {
    返回 "    <script type=\"application/ld+json\">"
        + JSONLD文档(节点们)
        + "</script>\n";
}

// ══════════════ robots.txt / sitemap.xml ══════════════

// 生成 robots.txt 全文：放行全部 + 显式放行主流 AI 爬虫（否则不能被引用），指向 sitemap。
// 站点地图URL 传空串则不写 Sitemap 行。
公开 函数 生成robots(站点地图URL: 字符串) : 字符串 {
    变量 输出: 字符串 = "User-agent: *\nAllow: /\n\n";
    输出 = 输出 + "User-agent: GPTBot\nAllow: /\n";
    输出 = 输出 + "User-agent: ChatGPT-User\nAllow: /\n";
    输出 = 输出 + "User-agent: OAI-SearchBot\nAllow: /\n";
    输出 = 输出 + "User-agent: PerplexityBot\nAllow: /\n";
    输出 = 输出 + "User-agent: ClaudeBot\nAllow: /\n";
    输出 = 输出 + "User-agent: anthropic-ai\nAllow: /\n";
    输出 = 输出 + "User-agent: Google-Extended\nAllow: /\n";
    输出 = 输出 + "User-agent: Bingbot\nAllow: /\n";
    如果 (字符串::字节长度(站点地图URL) > 0) {
        输出 = 输出 + "\nSitemap: " + 站点地图URL + "\n";
    }
    返回 输出;
}

// 生成 sitemap.xml：URL多行 = 每行一个绝对 URL（用 "\n" 分隔）。
公开 函数 生成站点地图(URL多行: 字符串) : 字符串 {
    变量 输出: 字符串 = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n";
    输出 = 输出 + "<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n";
    变量 总长: 整数 = 字符串::字节长度(URL多行);
    变量 起: 整数 = 0;
    变量 i: 整数 = 0;
    当 (i <= 总长) {
        变量 到行尾: 整数 = 0;
        如果 (i == 总长) { 到行尾 = 1; }
        如果 (到行尾 == 0 与 字符串::等于(字符串::子串(URL多行, i, 1), "\n") == 1) {
            到行尾 = 1;
        }
        如果 (到行尾 == 1) {
            变量 一行: 字符串 = 字符串::去空白(字符串::子串(URL多行, 起, i - 起));
            如果 (字符串::字节长度(一行) > 0) {
                输出 = 输出 + "  <url><loc>" + 一行 + "</loc></url>\n";
            }
            起 = i + 1;
        }
        i = i + 1;
    }
    输出 = 输出 + "</urlset>\n";
    返回 输出;
}
