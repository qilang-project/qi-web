// Qi Web - 实时广播（PubSub / 跨连接共享实时页面）
//
// 定位：在 实时页面.qi（每连接独立状态、无广播）之上，补一层**框架级 PubSub**，
// 让「同一 topic（如同一个家庭）」的所有 WebSocket 连接**共享同一份状态并互相广播**。
// 任一连接触发事件 → 服务端改共享状态（通常落 DB）→ 广播重渲染给该 topic 全部连接。
//
// ── 心跳：已从「必需」降级为「可选保活」（2026-07-16 运行时根治）──────────
// 【历史】早期运行时 WS 连接池是一把全局 Mutex，`WS::接收文本` 在阻塞读期间独占它，
//   导致向一个 park 在 接收文本 的连接 push 会一直阻塞——纯服务端广播发不出去。
//   当时的破解是客户端每 ~200ms 发 __心跳__ 逼 接收文本 周期性返回、释放锁。
// 【现在已修】运行时把 WS 池改成 Arc<连接>（qi-runtime/src/io/websocket_ffi.rs）：
//   recv 用 &TcpStream 读、不加锁；send 走各连接独立的 send_lock；两者互不阻塞。
//   → **广播 push 到正在 recv 的连接立即成功，不再依赖心跳**（实测：订阅方全程不发
//   任何帧也能收到广播）。心跳现在纯做保活/探活，间隔可放大到数十秒甚至去掉。
//   为兼容老运行时、并顺带做保活，客户端仍保留一个心跳，但不再是广播的命门。
//
// ── 并发与死锁 ────────────────────────────────────────────────
// 本模块自己维护一把 同步锁 保护 topic→连接集合 的注册表。广播时**先在锁内抓一份
// 连接句柄快照，出锁后再逐个发送**——发送不阻塞（目标 recv 与 send 各用各的锁），
// 且此刻本 goroutine 不持有任何我们自己的锁，注册表锁与连接池锁永不嵌套，故无死锁。
//
// ── 不破坏既有 实时路由 ────────────────────────────────────────
// 全部新增函数，不改 实时页面.qi 一行；每连接独立状态那套照旧可用。
//
// ── 协议 ──────────────────────────────────────────────────────
//   连接后客户端首帧必须是订阅：{"事件":"__订阅__","载荷": <订阅载荷JSON>}
//     准入函数(订阅载荷JSON) 校验（如验 session token）→ 返回 topic（空串=拒绝断开）
//   之后：
//     {"事件":"__心跳__","载荷":{}}         —— 仅用于释放锁，服务端不处理不渲染
//     {"事件":"<业务事件>","载荷":{...}}    —— 事件处理函数(topic,事件,载荷)：返回 1 广播 / 0 只回发自己
//   下行：{"html":"<片段>"}  客户端替换 #qi-live 内容（与 实时页面 同构）
包 Web;

导入 标准库.字符串;
导入 标准库.WebSocket 作为 WS;
导入 标准库.JSON 作为 J;
导入 标准库.列表 作为 列表库;
导入 标准库.同步 作为 同步;

// ── 注册 WS 广播端点 ────────────────────────────────────────────
//
// 只注册 WebSocket 端点（不含页面）；页面由 App 自己用 共享实时脚本 内嵌运行时后
// 通过 获取 挂载（这样 App 能做鉴权门禁、套自己的暖色布局）。
//   ws路径          WebSocket 路径（ASCII，如 "/board/ws"）
//   准入函数        函数(订阅载荷JSON:字符串):字符串 —— 校验并返回 topic（空=拒绝）
//   渲染函数        函数(topic:字符串):字符串 —— topic → HTML 片段（通常读 DB）
//   事件处理函数    函数(topic:字符串, 事件名:字符串, 载荷JSON:字符串):整数
//                     返回 1 = 处理后广播重渲染给该 topic 全体；0 = 只回发当前连接
公开 函数 共享WS路由(应用值: 应用, ws路径: 字符串, 准入函数: 函数(字符串): 字符串, 渲染函数: 函数(字符串): 字符串, 事件处理函数: 函数(字符串, 字符串, 字符串): 整数) : 应用 {
    // 每个广播端点一套独立注册表：一把锁 + 一个 topic→整数列表句柄 的 J 映射。
    // 这两个都是全局 slab 里的整数句柄，闭包按值捕获后每个连接 goroutine 拿到的是
    // 同一份底层结构（指向同一 slab 项），故天然跨连接共享。
    变量 广播锁: 整数 = 同步::创建锁();
    变量 连接表: 整数 = J.创建对象();

    变量 ws处理器: 函数(整数): 整数 = 闭包(ws句柄: 整数): 整数 {
        返回 广播连接循环(ws句柄, 广播锁, 连接表, 准入函数, 渲染函数, 事件处理函数);
    };
    应用值 = WS路由(应用值, ws路径, ws处理器);
    返回 应用值;
}

// ── 每连接事件循环 ──────────────────────────────────────────────

函数 广播连接循环(ws句柄: 整数, 广播锁: 整数, 连接表: 整数, 准入函数: 函数(字符串): 字符串, 渲染函数: 函数(字符串): 字符串, 事件处理函数: 函数(字符串, 字符串, 字符串): 整数) : 整数 {
    // 1. 首帧握手：必须是 __订阅__，取出订阅载荷交给准入函数校验
    变量 首帧: 字符串 = WS::接收文本(ws句柄);
    如果 (字符串::字节长度(首帧) == 0) {
        返回 0;
    }
    变量 订阅载荷: 字符串 = 取载荷串(首帧, "__订阅__");
    如果 (字符串::字节长度(订阅载荷) == 0) {
        返回 0;
    }
    变量 topic: 字符串 = 准入函数(订阅载荷);
    如果 (字符串::字节长度(topic) == 0) {
        // 校验失败：拒绝
        返回 0;
    }

    // 2. 订阅该 topic，并推一帧初始渲染给自己
    广播订阅(广播锁, 连接表, topic, ws句柄);
    广播发送整区(ws句柄, 渲染函数(topic));

    // 3. 事件循环
    变量 继续循环: 整数 = 1;
    当 (继续循环 == 1 与 WS::已连接(ws句柄) == 1) {
        变量 消息: 字符串 = WS::接收文本(ws句柄);
        如果 (字符串::字节长度(消息) == 0) {
            继续循环 = 0;
        } 否则 {
            变量 消息对象: 整数 = J.解码(消息);
            如果 (消息对象 > 0) {
                变量 事件名: 字符串 = J.获取字符串(消息对象, "事件");
                // 心跳帧：只为让 接收文本 返回、释放连接池锁；不处理不渲染
                如果 (字符串::等于(事件名, "__心跳__") == 1) {
                    // no-op
                } 否则 {
                    如果 (字符串::字节长度(事件名) > 0) {
                        变量 载荷串: 字符串 = "{}";
                        如果 (J.是否包含键(消息对象, "载荷") == 1) {
                            变量 载荷对象: 整数 = J.获取对象(消息对象, "载荷");
                            如果 (载荷对象 > 0) {
                                载荷串 = J.转字符串(载荷对象);
                            }
                        }
                        变量 需广播: 整数 = 事件处理函数(topic, 事件名, 载荷串);
                        如果 (需广播 == 1) {
                            // 广播重渲染给该 topic 全体（含自己）
                            广播(广播锁, 连接表, topic, 渲染函数(topic));
                        } 否则 {
                            // 只回发自己
                            广播发送整区(ws句柄, 渲染函数(topic));
                        }
                    }
                }
                J.删除(消息对象);
            }
        }
    }

    // 4. 断开：退订
    广播退订(广播锁, 连接表, topic, ws句柄);
    返回 0;
}

// 从一帧 JSON 里取指定事件名的载荷子对象文本；事件名不匹配返回 ""
函数 取载荷串(帧文本: 字符串, 期望事件: 字符串) : 字符串 {
    变量 帧对象: 整数 = J.解码(帧文本);
    如果 (帧对象 <= 0) {
        返回 "";
    }
    变量 事件名: 字符串 = J.获取字符串(帧对象, "事件");
    如果 (字符串::等于(事件名, 期望事件) == 0) {
        J.删除(帧对象);
        返回 "";
    }
    变量 载荷串: 字符串 = "{}";
    如果 (J.是否包含键(帧对象, "载荷") == 1) {
        变量 载荷对象: 整数 = J.获取对象(帧对象, "载荷");
        如果 (载荷对象 > 0) {
            载荷串 = J.转字符串(载荷对象);
        }
    }
    J.删除(帧对象);
    返回 载荷串;
}

// ── PubSub 注册表：订阅 / 退订 / 广播 ────────────────────────────
//
// 注册表结构：连接表 是一个 J 对象，键=topic，值=一个 标准库.列表 的「整数列表句柄」
// （存该 topic 下所有活跃 WS 句柄）。所有读写都在 广播锁 内串行，故底层 J / 列表
// 句柄无需各自线程安全。

公开 函数 广播订阅(广播锁: 整数, 连接表: 整数, topic: 字符串, ws句柄: 整数) : 整数 {
    同步::加锁(广播锁);
    变量 列表句柄: 整数 = 取或建列表(连接表, topic);
    如果 (列表库::包含整数(列表句柄, ws句柄) == 0) {
        列表库::添加整数(列表句柄, ws句柄);
    }
    同步::解锁(广播锁);
    返回 1;
}

公开 函数 广播退订(广播锁: 整数, 连接表: 整数, topic: 字符串, ws句柄: 整数) : 整数 {
    同步::加锁(广播锁);
    如果 (J.是否包含键(连接表, topic) == 1) {
        变量 列表句柄: 整数 = J.获取整数(连接表, topic);
        变量 索引: 整数 = 列表库::查找整数索引(列表句柄, ws句柄);
        如果 (索引 >= 0) {
            列表库::删除整数元素(列表句柄, 索引);
        }
    }
    同步::解锁(广播锁);
    返回 1;
}

// 向 topic 全体连接广播一帧片段。返回成功发送的连接数。
// 关键：先在锁内抓句柄快照，出锁后再发送——发送阻塞等待各连接释放连接池锁
// （≤ 一个心跳周期），此时不持有 广播锁，杜绝与连接池锁的嵌套死锁。
公开 函数 广播(广播锁: 整数, 连接表: 整数, topic: 字符串, 片段: 字符串) : 整数 {
    // 帧只序列化一次
    变量 帧对象: 整数 = J.创建对象();
    J.设置字符串(帧对象, "html", 片段);
    变量 帧文本: 字符串 = J.转字符串(帧对象);
    J.删除(帧对象);

    // 锁内抓快照
    同步::加锁(广播锁);
    变量 快照: 整数 = 列表库::创建整数列表();
    如果 (J.是否包含键(连接表, topic) == 1) {
        变量 列表句柄: 整数 = J.获取整数(连接表, topic);
        变量 总数: 整数 = 列表库::整数列表大小(列表句柄);
        变量 索引: 整数 = 0;
        当 (索引 < 总数) {
            列表库::添加整数(快照, 列表库::获取整数(列表句柄, 索引));
            索引 = 索引 + 1;
        }
    }
    同步::解锁(广播锁);

    // 出锁发送
    变量 成功数: 整数 = 0;
    变量 快照大小: 整数 = 列表库::整数列表大小(快照);
    变量 i: 整数 = 0;
    当 (i < 快照大小) {
        变量 目标句柄: 整数 = 列表库::获取整数(快照, i);
        如果 (WS::发送文本(目标句柄, 帧文本) == 1) {
            成功数 = 成功数 + 1;
        }
        i = i + 1;
    }
    列表库::删除列表(快照);
    返回 成功数;
}

// topic 不存在则新建一个整数列表并挂到连接表；返回列表句柄。调用方须已持锁。
函数 取或建列表(连接表: 整数, topic: 字符串) : 整数 {
    如果 (J.是否包含键(连接表, topic) == 1) {
        返回 J.获取整数(连接表, topic);
    }
    变量 列表句柄: 整数 = 列表库::创建整数列表();
    J.设置整数(连接表, topic, 列表句柄);
    返回 列表句柄;
}

// 下行一帧 {"html":"..."} 给单个连接
函数 广播发送整区(ws句柄: 整数, 片段: 字符串) : 整数 {
    变量 帧对象: 整数 = J.创建对象();
    J.设置字符串(帧对象, "html", 片段);
    变量 帧文本: 字符串 = J.转字符串(帧对象);
    J.删除(帧对象);
    返回 WS::发送文本(ws句柄, 帧文本);
}

// ── 客户端运行时脚本 ────────────────────────────────────────────
//
// 供 App 内嵌进自己的鉴权页面（页面里须有 <div id="qi-live">初始片段</div>）。
//   ws路径        WebSocket 路径（如 "/board/ws"）
//   订阅载荷JSON  首帧 __订阅__ 的载荷（如 {"token":"..","家庭id":".."}）；每个事件也会
//                 自动并入其中的 昵称/成员id 字段，便于服务端识别操作者（v1 信任模型：
//                 topic 由 token 服务端校验，昵称仅作展示，见 README）
//   心跳毫秒      心跳间隔，建议 200；见文件头「为什么需要心跳」
公开 函数 共享实时脚本(ws路径: 字符串, 订阅载荷JSON: 字符串, 心跳毫秒: 整数) : 字符串 {
    变量 s: 字符串 = "<script>\n(function(){\n";
    s = s + "var wsPath='" + ws路径 + "';\n";
    s = s + "var sub=" + 订阅载荷JSON + ";\n";
    s = s + "var hb=" + 整数转字符串(心跳毫秒) + ";\n";
    s = s + "var ws=null, hbTimer=null;\n";
    s = s + "function ident(p){p=p||{};if(sub){if(sub['昵称']!==undefined)p['昵称']=sub['昵称'];";
    s = s + "if(sub['成员id']!==undefined)p['成员id']=sub['成员id'];}return p;}\n";
    s = s + "function send(ev,payload){if(ws&&ws.readyState===1){";
    s = s + "ws.send(JSON.stringify({'事件':ev,'载荷':ident(payload)}));}}\n";
    s = s + "function sendRaw(ev,payload){if(ws&&ws.readyState===1){";
    s = s + "ws.send(JSON.stringify({'事件':ev,'载荷':payload||{}}));}}\n";
    s = s + "function connect(){\n";
    s = s + "  var proto=location.protocol==='https:'?'wss://':'ws://';\n";
    s = s + "  ws=new WebSocket(proto+location.host+wsPath);\n";
    s = s + "  ws.onopen=function(){\n";
    s = s + "    sendRaw('__订阅__',sub);\n";
    s = s + "    if(hbTimer){clearInterval(hbTimer);}\n";
    s = s + "    hbTimer=setInterval(function(){sendRaw('__心跳__',{});},hb);\n";
    s = s + "  };\n";
    s = s + "  ws.onmessage=function(e){\n";
    s = s + "    var m;try{m=JSON.parse(e.data);}catch(err){return;}\n";
    s = s + "    if(m.html===undefined){return;}\n";
    s = s + "    var live=document.getElementById('qi-live');if(!live){return;}\n";
    s = s + "    var f=document.activeElement,fk=null,fv=null,s1=null,s2=null;\n";
    s = s + "    if(f&&f.getAttribute){fk=f.getAttribute('data-输入');fv=f.value;\n";
    s = s + "      try{s1=f.selectionStart;s2=f.selectionEnd;}catch(e2){}}\n";
    s = s + "    live.innerHTML=m.html;\n";
    s = s + "    if(fk){var nf=live.querySelector('[data-输入=\"'+fk+'\"]');\n";
    s = s + "      if(nf){nf.focus();if(fv!==null&&fv!==undefined){nf.value=fv;}\n";
    s = s + "        if(s1!==null){try{nf.setSelectionRange(s1,s2);}catch(e3){}}}}\n";
    s = s + "  };\n";
    s = s + "  ws.onclose=function(){if(hbTimer){clearInterval(hbTimer);}setTimeout(connect,1000);};\n";
    s = s + "}\n";
    s = s + "document.addEventListener('click',function(e){\n";
    s = s + "  var el=e.target.closest('[data-点击]');\n";
    s = s + "  if(el){send(el.getAttribute('data-点击'),{});}\n";
    s = s + "});\n";
    s = s + "document.addEventListener('input',function(e){\n";
    s = s + "  var el=e.target.closest('[data-输入]');\n";
    s = s + "  if(el){send(el.getAttribute('data-输入'),{value:el.value});}\n";
    s = s + "});\n";
    s = s + "document.addEventListener('submit',function(e){\n";
    s = s + "  var f4=e.target.closest('[data-提交]');\n";
    s = s + "  if(f4){e.preventDefault();var d={};\n";
    s = s + "    new FormData(f4).forEach(function(v,k){d[k]=v;});\n";
    s = s + "    send(f4.getAttribute('data-提交'),d);\n";
    s = s + "    f4.reset();}\n";
    s = s + "});\n";
    s = s + "connect();\n";
    s = s + "})();\n</script>";
    返回 s;
}
